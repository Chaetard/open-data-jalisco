# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
*.egg
build/
dist/

# Virtual envs
.venv/
venv/
env/

# uv
.uv/

# Caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDEs
.vscode/
.idea/
*.swp
.DS_Store

# Env / secrets
.env
.env.local
.env.*.local

# Override de compose para dev (bind-mount de ./src + uvicorn --reload). Es por
# máquina y NO debe llegar a prod; cada quien mantiene el suyo en local.
docker-compose.override.yml

# Local data — NEVER commit raw documents or generated manifests
data/
!data/.gitkeep

# Manifests are regenerated; only commit reference examples manually
datasets/manifests/*.json
!datasets/manifests/.gitkeep

# Discovered candidates are regenerated by `sapumu scan`. Can be large and
# user-specific; only commit reference examples manually.
datasets/discovered/
!datasets/discovered/.gitkeep
# Scan outputs dropped next to source YAMLs (e.g. tequila_candidates_full.json)
# are regenerable scratch — never commit them.
datasets/sources/*_candidates*.json
datasets/sources/*_candidates*.yaml
datasets/sources/*_candidates*.yml

# High-res media masters kept locally for re-encoding; commit only the
# web-optimized derivative (e.g. video_hero.mp4), never the *.master.* original.
*.master.mp4
*.master.mov

# Claude Code / agent-specific local settings
.claude/

# Logs
*.log
logs/

# Personal maintainer notes — not for publication
WALKTHROUGH.md
TICKETS.md
