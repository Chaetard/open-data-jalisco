# open-data-jalisco — example configuration
# Copia este archivo a `.env` y ajusta valores. Nunca commitees `.env`.

# --- Entorno ---
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- Base de datos (Postgres + pgvector) ---
# Para uso local con docker-compose:
DATABASE_URL=postgresql+psycopg://odj:odj@localhost:5432/open_data_jalisco

# --- Raw storage local ---
# Carpeta donde se guardan los documentos originales. Idempotente, organizada por hash.
RAW_STORAGE_PATH=./data/raw

# --- Manifests ---
# Carpeta donde se escriben los manifests JSON de integridad técnica.
MANIFESTS_DIR=./datasets/manifests

# --- Embeddings ---
# Providers disponibles:
#   - "dummy":    vector determinista por SHA-256. Sin red, sin API key, SIN semántica
#                 real. Útil para tests, inútil para búsqueda.
#   - "local_st": sentence-transformers ejecutado localmente (CPU o CUDA). Requiere
#                 instalar el extra: `uv sync --extra local-embed`. Modelo por defecto
#                 `intfloat/multilingual-e5-small` (384d, multilingüe, ~470 MB).
EMBEDDING_PROVIDER=dummy
EMBEDDING_MODEL=dummy-v1
# IMPORTANTE: si cambias la dimensión después de crear las tablas, debes recrear la
# columna pgvector. Para MVP usamos 384 (compatible con multilingual-e5-small).
EMBEDDING_DIMENSION=384
# Sólo aplica a `local_st`. Ignorado por `dummy`.
EMBEDDING_DEVICE=cpu

# Para activar el embedder local descomenta y reemplaza los tres valores anteriores:
# EMBEDDING_PROVIDER=local_st
# EMBEDDING_MODEL=intfloat/multilingual-e5-small
# EMBEDDING_DIMENSION=384

# --- Reranking (opcional, mejora la precisión de búsqueda) ---
# Etapa cross-encoder que reordena el top-N del vector antes de cortar al limit.
# Corrige el caso "presupuesto municipal", donde el embedder chico no separa los
# documentos del *Estado* de Jalisco de los del municipio. Reusa el extra
# `local-embed` (CrossEncoder viene con sentence-transformers, no instala nada nuevo).
#   - "none":          desactivado (default). Cero coste, comportamiento idéntico.
#   - "cross_encoder": rerankea con un cross-encoder multilingüe (~470 MB).
RERANK_PROVIDER=none
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANK_DEVICE=cpu
# Candidatos recuperados (rerankeados / filtrados por jurisdicción) antes de
# cortar al limit. Más alto = mejor recall antes del rerank, más lento.
RERANK_POOL=50

# --- Scraping ---
SCRAPER_USER_AGENT=open-data-jalisco/0.1 (+https://github.com/your-org/open-data-jalisco)
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF_SECONDS=2

# --- Chunking ---
CHUNK_MAX_CHARS=1800
CHUNK_OVERLAP_CHARS=200
CHUNK_MIN_CHARS=120

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
